@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Dashboard Quản trị</h2>
        <div>
            <a href="@Url.Action("Index", "Order")" class="btn btn-primary me-2"><i class="fas fa-box"></i> Quản lý Đơn hàng</a>
            <a href="@Url.Action("Index", "User")" class="btn btn-secondary"><i class="fas fa-users"></i> Quản lý Người dùng</a>
        </div>
    </div>

    <!-- Metrics Cards -->
    <div class="row g-4 mb-5">
        <!-- Doanh thu ngày -->
        <div class="col-md-3">
            <div class="card bg-success text-white h-100 shadow-sm border-0 rounded-pills-custom">
                <div class="card-body py-4 text-center">
                    <h5 class="card-title text-uppercase mb-3" style="font-size: 0.9rem; letter-spacing: 1px;">Doanh thu Hôm nay</h5>
                    <h3 class="card-text fw-bold">@ViewBag.DailyRevenue.ToString("#,##0") đ</h3>
                    <div class="mt-3"><i class="fas fa-money-bill-wave fa-2x opacity-50"></i></div>
                </div>
            </div>
        </div>

        <!-- Doanh thu tháng -->
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100 shadow-sm border-0 rounded-pills-custom">
                <div class="card-body py-4 text-center">
                    <h5 class="card-title text-uppercase mb-3" style="font-size: 0.9rem; letter-spacing: 1px;">Doanh thu Tháng này</h5>
                    <h3 class="card-text fw-bold">@ViewBag.MonthlyRevenue.ToString("#,##0") đ</h3>
                    <div class="mt-3"><i class="fas fa-wallet fa-2x opacity-50"></i></div>
                </div>
            </div>
        </div>

        <!-- Số đơn mới -->
        <div class="col-md-3">
            <div class="card bg-warning text-dark h-100 shadow-sm border-0 rounded-pills-custom">
                <div class="card-body py-4 text-center">
                    <h5 class="card-title text-uppercase mb-3" style="font-size: 0.9rem; letter-spacing: 1px;">Số đơn Mới</h5>
                    <h3 class="card-text fw-bold">@ViewBag.NewOrdersCount</h3>
                    <div class="mt-3"><i class="fas fa-bell fa-2x opacity-50"></i></div>
                </div>
            </div>
        </div>

        <!-- Tỉ lệ thành công/hủy -->
        <div class="col-md-3">
            <div class="card bg-danger text-white h-100 shadow-sm border-0 rounded-pills-custom">
                <div class="card-body py-4 text-center">
                    <h5 class="card-title text-uppercase mb-3" style="font-size: 0.9rem; letter-spacing: 1px;">Tỉ lệ Giao Thành công</h5>
                    <h3 class="card-text fw-bold">@ViewBag.SuccessRate%</h3>
                    <div class="mt-3">
                        <small class="d-block text-white-50">Thành công: @ViewBag.SuccessOrdersCount</small>
                        <small class="d-block text-white-50">Hủy: @ViewBag.CancelledOrdersCount</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-4">Biểu đồ Trạng thái Đơn hàng Đã Xử Lý</h5>
                    <div class="progress" style="height: 30px; font-size: 1rem;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: @ViewBag.SuccessRate%;" aria-valuenow="@ViewBag.SuccessRate" aria-valuemin="0" aria-valuemax="100">
                            @if(ViewBag.SuccessRate > 5) { <text>@ViewBag.SuccessRate% Thành công</text> }
                        </div>
                        <div class="progress-bar bg-danger" role="progressbar" style="width: @(100 - ViewBag.SuccessRate)%;" aria-valuenow="@(100 - ViewBag.SuccessRate)" aria-valuemin="0" aria-valuemax="100">
                             @if(100 - ViewBag.SuccessRate > 5) { <text>@(100 - ViewBag.SuccessRate)% Hủy</text> }
                        </div>
                    </div>
                    <div class="mt-3 d-flex justify-content-center text-muted">
                        <span class="me-4"><i class="fas fa-circle text-success me-1"></i> Giao Thành công</span>
                        <span><i class="fas fa-circle text-danger me-1"></i> Khách Hủy / Giao Thất bại</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue Chart -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-4">Biểu đồ Doanh thu (7 ngày gần nhất)</h5>
                    <canvas id="revenueChart" height="80"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Products -->
    <div class="row mt-4 mb-5">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-4">Top 5 Sản Phẩm Bán Chạy Nhất</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">#</th>
                                    <th scope="col">Hình ảnh</th>
                                    <th scope="col">Tên món</th>
                                    <th scope="col">Đã bán</th>
                                    <th scope="col">Doanh thu mang lại</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var topProducts = ViewBag.TopProducts as IEnumerable<dynamic>;
                                    int rank = 1;
                                    if (topProducts != null && topProducts.Any())
                                    {
                                        foreach (var item in topProducts)
                                        {
                                            <tr>
                                                <th scope="row">@rank</th>
                                                <td>
                                                    <img src="~/images/@item.Image" alt="@item.Name" class="img-thumbnail" style="width: 50px; height: 50px; object-fit: cover;">
                                                </td>
                                                <td class="fw-bold">@item.Name</td>
                                                <td><span class="badge bg-success rounded-pill px-3 py-2">@item.TotalQuantity</span></td>
                                                <td class="text-danger fw-bold">@item.TotalRevenue.ToString("#,##0") đ</td>
                                            </tr>
                                            rank++;
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center py-4 text-muted">Chưa có dữ liệu sản phẩm bán ra.</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var ctx = document.getElementById('revenueChart').getContext('2d');
            
            var labels = @Html.Raw(ViewBag.ChartLabels);
            var data = @Html.Raw(ViewBag.ChartData);

            var gradient = ctx.createLinearGradient(0, 0, 0, 400);
            gradient.addColorStop(0, 'rgba(243, 95, 42, 0.5)');
            gradient.addColorStop(1, 'rgba(243, 95, 42, 0.05)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu',
                        data: data,
                        borderColor: '#F35F2A',
                        backgroundColor: gradient,
                        borderWidth: 3,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#F35F2A',
                        pointHoverBackgroundColor: '#F35F2A',
                        pointHoverBorderColor: '#fff',
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.y !== null) {
                                        label += new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(context.parsed.y);
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value, index, values) {
                                    if(value >= 1000000) return (value / 1000000) + ' Tr';
                                    if(value >= 1000) return (value / 1000) + ' k';
                                    return value;
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}

<style>
    .rounded-pills-custom {
        border-radius: 15px;
    }
    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>
