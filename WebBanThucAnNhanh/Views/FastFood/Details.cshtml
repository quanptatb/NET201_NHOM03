@model WebBanThucAnNhanh.Models.FastFood
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml"; // Trỏ về layout admin mới tạo
}
@{
    ViewData["Title"] = "Chi Tiết Món Ăn";
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Danh sách món</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.NameFastFood</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-5 mb-4 mb-md-0">
                    <div class="position-relative overflow-hidden rounded shadow-sm text-center bg-light"
                         style="min-height: 300px;">
                        @if (!string.IsNullOrEmpty(Model.Image))
                        {
                            <img src="~/images/@Model.Image" alt="@Model.NameFastFood" class="img-fluid"
                                 style="object-fit: contain; max-height: 400px; width: 100%;" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                <span>Chưa có hình ảnh</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-md-7">
                    <h1 class="display-6 fw-bold text-dark mb-2">@Model.NameFastFood</h1>

                    <div class="mb-3">
                        <span class="badge bg-primary me-2">
                            <i class="bi bi-tag-fill"></i> @Html.DisplayFor(model =>
                                                        model.TypeOfFastFood.NameTypeOfFastFood)
                        </span>
                        @if (Model.Theme != null)
                        {
                            <span class="badge bg-info text-dark">
                                <i class="bi bi-stars"></i> @Model.Theme.NameTheme
                            </span>
                        }
                    </div>

                    <div class="mb-4">
                        <h2 class="text-danger fw-bold">@Model.Price.ToString("N0") đ</h2>
                    </div>

                    <div class="mb-4">
                        <h5 class="fw-bold">Mô tả:</h5>
                        <p class="text-secondary" style="line-height: 1.6;">
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                @Model.Description
                            }
                            else
                            {
                                <i>Đang cập nhật mô tả...</i>
                            }
                        </p>
                    </div>

                    <hr />
                    <div class="options-section mb-4">
                        <form id="addToCartForm">
                            @if (Model.FastFoodOptionGroups != null && Model.FastFoodOptionGroups.Any())
                            {
                                @foreach (var fog in Model.FastFoodOptionGroups)
                                {
                                    <div class="option-group mb-3">
                                        <h6 class="fw-bold text-uppercase" style="font-size: 0.9rem;">
                                            @fog.OptionGroup.Name
                                            <span class="text-muted small">@(fog.OptionGroup.IsMultiSelect ? "(Chọn nhiều)" :
                                                                                        "(Chọn 1)")</span>
                                            </h6>
                                            <div class="d-flex flex-wrap gap-2">
                                                @foreach (var item in fog.OptionGroup.OptionItems)
                                                {
                                                    <div class="option-item">
                                                        @if (fog.OptionGroup.IsMultiSelect)
                                                        {
                                                            <input type="checkbox" class="btn-check" id="item-@item.Id"
                                                                   name="selectedOptions" value="@item.Id" autocomplete="off">
                                                            <label class="btn btn-outline-danger btn-sm" for="item-@item.Id">
                                                                @item.Name (+@item.AdditionalPrice.ToString("N0")đ)
                                                            </label>
                                                        }
                                                        else
                                                        {
                                                            <input type="radio" class="btn-check" id="item-@item.Id"
                                                                   name="group-@fog.OptionGroupId" value="@item.Id" autocomplete="off" @(item
                                                                                                                                                                                                                        == fog.OptionGroup.OptionItems.First() ? "checked" : "")>
                                                            <label class="btn btn-outline-primary btn-sm" for="item-@item.Id">
                                                                @item.Name (+@item.AdditionalPrice.ToString("N0")đ)
                                                            </label>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            </form>
                        </div>

                        <div class="row mb-4">
                            <div class="col-6">
                                <small class="text-muted fw-bold d-block">TÌNH TRẠNG</small>
                                @if (Model.Status && Model.Quantity > 0)
                                {
                                    <span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> Còn hàng</span>
                                }
                                else
                                {
                                    <span class="text-danger fw-bold"><i class="bi bi-x-circle-fill"></i> Hết hàng / Ngừng
                                        bán</span>
                                    }
                                </div>
                                <div class="col-6">
                                    <small class="text-muted fw-bold d-block">SỐ LƯỢNG KHO</small>
                                    <span class="fw-bold">@Model.Quantity</span>
                                </div>
                            </div>

                            <div class="d-flex gap-2 mt-auto">
                                <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model?.IdFastFood"
                                       class="btn btn-danger px-4 fw-bold">
                                    <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                                </a>

                                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4">
                                    <i class="bi bi-arrow-left"></i> Tiếp tục mua hàng
                                </a>
                            </div>
                            <div class="mt-4">
                                <h5 class="fw-bold"><i class="bi bi-plus-circle"></i> Tùy chọn thêm:</h5>
                                <form id="toppingForm">
                                    @if (Model.FastFoodOptionGroups != null && Model.FastFoodOptionGroups.Any())
                                    {
                                        @foreach (var fog in Model.FastFoodOptionGroups)
                                        {
                                            <div class="mb-3 border-bottom pb-2">
                                                <label class="form-label fw-bold text-primary">@fog.OptionGroup.Name</label>
                                                <div class="d-flex flex-wrap gap-2">
                                                    @foreach (var item in fog.OptionGroup.OptionItems)
                                                    {
                                                        <div class="form-check border rounded p-2">
                                                            @if (fog.OptionGroup.IsMultiSelect)
                                                            {
                                                                <input class="form-check-input ms-0" type="checkbox" name="toppingIds"
                                                                       value="@item.Id" id="item-@item.Id">
                                                            }
                                                            else
                                                            {
                                                                <input class="form-check-input ms-0" type="radio"
                                                                       name="group-@fog.OptionGroupId" value="@item.Id" id="item-@item.Id">
                                                            }
                                                            <label class="form-check-label ps-4" for="item-@item.Id">
                                                                @item.Name <span
                                                                class="text-danger">(+@item.AdditionalPrice.ToString("N0")đ)</span>
                                                            </label>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <p class="text-muted small"><i>Món này không có tùy chọn thêm.</i></p>
                                    }
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>