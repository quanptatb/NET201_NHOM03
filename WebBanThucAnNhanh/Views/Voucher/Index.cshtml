@model IEnumerable<WebBanThucAnNhanh.Models.Voucher>

@{
    ViewData["Title"] = "Quản lý Mã giảm giá";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-ticket-alt"></i> Quản lý Mã giảm giá</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Tạo mới</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark text-center">
            <tr>
                <th>Mã</th>
                <th>Loại giảm</th>
                <th>Giá trị</th>
                <th>Giảm tối đa</th>
                <th>Đơn tối thiểu</th>
                <th>Hết hạn</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@item.Code</td>
                    <td class="text-center text-nowrap">
                        @(item.DiscountType == 1 ? "Phần trăm (%)" : "Số tiền (đ)")
                    </td>
                    <td class="text-end text-nowrap">
                        @(item.DiscountType == 1 ? item.DiscountValue.ToString("0.##") + "%" : item.DiscountValue.ToString("n0") + "đ")
                    </td>
                    <td class="text-end text-nowrap text-muted">
                        @(item.DiscountType == 1 && item.MaxDiscountAmount > 0 ? item.MaxDiscountAmount.ToString("n0") + "đ" : "-")
                    </td>
                    <td class="text-end text-nowrap">
                        @item.MinOrderValue.ToString("n0") đ
                    </td>
                    <td class="text-center text-nowrap @(item.ExpiryDate < DateTime.Now ? "text-danger" : "")">
                        @item.ExpiryDate.ToString("dd/MM/yyyy HH:mm")
                    </td>
                    <td class="text-center">
                        @if (item.IsActive && item.ExpiryDate >= DateTime.Now)
                        {
                            <span class="badge bg-success">Đang hoạt động</span>
                        }
                        else if (!item.IsActive)
                        {
                            <span class="badge bg-secondary">Đã vô hiệu</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Đã hết hạn</span>
                        }
                    </td>
                    <td class="text-center text-nowrap">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Sửa"><i class="fas fa-edit"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
