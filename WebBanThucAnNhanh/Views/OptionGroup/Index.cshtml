@model IEnumerable<WebBanThucAnNhanh.Models.OptionGroup>
@{
    ViewData["Title"] = "Quản lý Topping & Tùy chọn";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Quản lý Topping & Tùy chọn</h2>
        <a asp-action="CreateGroup" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm Nhóm Tùy Chọn</a>
    </div>

    <div class="row">
        @foreach (var group in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            @group.Name 
                            <span class="badge bg-secondary ms-2 text-sm">@(group.IsMultiSelect ? "Chọn nhiều" : "Chọn một")</span>
                        </h5>
                        <form asp-action="DeleteGroup" asp-route-id="@group.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa nhóm này và toàn bộ lựa chọn con?');">
                            <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Xóa nhóm</button>
                        </form>
                    </div>
                    <div class="card-body">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Tên lựa chọn</th>
                                    <th>Giá cộng thêm</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in group.OptionItems)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>+@item.AdditionalPrice.ToString("N0") đ</td>
                                        <td>
                                            <form asp-action="DeleteItem" asp-route-id="@item.Id" method="post">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa tùy chọn này?');">Xóa</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <div class="text-end mt-2">
                            <a asp-action="CreateItem" asp-route-groupId="@group.Id" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-plus-circle"></i> Thêm lựa chọn mới
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>