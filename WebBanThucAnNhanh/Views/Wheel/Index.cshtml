@{
    ViewData["Title"] = "Vòng quay may mắn";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var drinkSpins = (int)ViewBag.DrinkSpins;
    var foodSpins = (int)ViewBag.FoodSpins;
    var drinkPrizes = ViewBag.DrinkPrizes as List<WebBanThucAnNhanh.Models.WheelPrize>;
    var foodPrizes = ViewBag.FoodPrizes as List<WebBanThucAnNhanh.Models.WheelPrize>;
}

@section Scripts {
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // === DỮ LIỆU TỪ SERVER ===
        let drinkSpins = @drinkSpins;
        let foodSpins = @foodSpins;
        let currentTab = 1; // 1: Nước, 2: Đồ ăn
        let isSpinning = false;

        const drinkPrizes = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
            drinkPrizes.OrderBy(p => p.Id).Select(p => new { id = p.Id, name = p.PrizeName })
        ));

        const foodPrizes = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
            foodPrizes.OrderBy(p => p.Id).Select(p => new { id = p.Id, name = p.PrizeName })
        ));

        // === KHỞI TẠO ===
        $(document).ready(function () {
            switchTab(1);
        });

        function switchTab(tab) {
            currentTab = tab;
            if (tab === 1) {
                $('#tabDrink').addClass('active');
                $('#tabFood').removeClass('active');
                $('#spinCount').text(drinkSpins);
                $('#spinLabel').text('lượt quay Nước');
                drawWheel(drinkPrizes);
            } else {
                $('#tabFood').addClass('active');
                $('#tabDrink').removeClass('active');
                $('#spinCount').text(foodSpins);
                $('#spinLabel').text('lượt quay Đồ ăn');
                drawWheel(foodPrizes);
            }
            // Reset wheel rotation
            $('#wheelCanvas').css('transform', 'rotate(0deg)');
        }

        // === VẼ VÒNG QUAY BẰNG CANVAS ===
        function drawWheel(prizes) {
            const canvas = document.getElementById('wheelCanvas');
            const ctx = canvas.getContext('2d');
            const size = canvas.width;
            const center = size / 2;
            const radius = center - 5;
            const numSlices = prizes.length;

            if (numSlices === 0) {
                ctx.clearRect(0, 0, size, size);
                ctx.font = 'bold 20px Catamaran, sans-serif';
                ctx.fillStyle = '#666';
                ctx.textAlign = 'center';
                ctx.fillText('Chưa có giải thưởng', center, center);
                return;
            }

            const sliceAngle = (2 * Math.PI) / numSlices;

            // Bảng màu premium
            const colors = [
                '#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4',
                '#FFEAA7', '#DDA0DD', '#98D8C8', '#F7DC6F',
                '#BB8FCE', '#85C1E9', '#F0B27A', '#82E0AA',
                '#F1948A', '#AED6F1', '#D5DBDB', '#FAD7A0'
            ];

            ctx.clearRect(0, 0, size, size);

            // Vẽ từng phần
            for (let i = 0; i < numSlices; i++) {
                const startAngle = i * sliceAngle;
                const endAngle = (i + 1) * sliceAngle;
                const color = colors[i % colors.length];

                // Vẽ sector
                ctx.beginPath();
                ctx.moveTo(center, center);
                ctx.arc(center, center, radius, startAngle, endAngle);
                ctx.closePath();
                ctx.fillStyle = color;
                ctx.fill();
                ctx.strokeStyle = 'rgba(255,255,255,0.8)';
                ctx.lineWidth = 2;
                ctx.stroke();

                // Vẽ text
                ctx.save();
                ctx.translate(center, center);
                ctx.rotate(startAngle + sliceAngle / 2);

                ctx.fillStyle = '#2c3e50';
                ctx.font = 'bold 14px Catamaran, sans-serif';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';

                // Cắt text nếu quá dài
                let text = prizes[i].name;
                if (text.length > 14) text = text.substring(0, 12) + '..';

                ctx.fillText(text, radius * 0.62, 0);
                ctx.restore();
            }

            // Vẽ tâm vòng quay
            ctx.beginPath();
            ctx.arc(center, center, 28, 0, 2 * Math.PI);
            ctx.fillStyle = '#2c3e50';
            ctx.fill();
            ctx.strokeStyle = '#fff';
            ctx.lineWidth = 3;
            ctx.stroke();

            ctx.beginPath();
            ctx.arc(center, center, 18, 0, 2 * Math.PI);

            let gradient = ctx.createRadialGradient(center, center, 0, center, center, 18);
            gradient.addColorStop(0, '#f39c12');
            gradient.addColorStop(1, '#e74c3c');
            ctx.fillStyle = gradient;
            ctx.fill();
        }

        // === XÁO TRỘN VÒNG QUAY ===
        function shuffleWheel() {
            if (isSpinning) return;
            const prizes = currentTab === 1 ? drinkPrizes : foodPrizes;
            // Fisher-Yates Shuffle
            for (let i = prizes.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [prizes[i], prizes[j]] = [prizes[j], prizes[i]];
            }
            drawWheel(prizes);
            $('#wheelCanvas').css({ 'transition': 'none', 'transform': 'rotate(0deg)' });
        }

        // === QUAY THƯỞNG ===
        function spinWheel() {
            if (isSpinning) return;

            const spins = currentTab === 1 ? drinkSpins : foodSpins;
            const prizes = currentTab === 1 ? drinkPrizes : foodPrizes;

            if (spins <= 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Hết lượt quay!',
                    text: currentTab === 1
                        ? 'Bạn không còn lượt quay Nước. Hãy mua đơn từ 100.000đ để nhận thêm!'
                        : 'Bạn không còn lượt quay Đồ ăn. Hãy mua đơn từ 200.000đ để nhận thêm!',
                    confirmButtonColor: '#e74c3c'
                });
                return;
            }

            if (prizes.length === 0) {
                Swal.fire({
                    icon: 'info',
                    title: 'Chưa có giải thưởng',
                    text: 'Vòng quay hiện chưa có giải thưởng nào. Hãy quay lại sau!',
                    confirmButtonColor: '#3085d6'
                });
                return;
            }

            isSpinning = true;
            $('#btnSpin').prop('disabled', true).text('Đang quay...');

            // Gọi API
            $.ajax({
                url: '/Wheel/Spin',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ spinType: currentTab }),
                success: function (result) {
                    if (!result.success) {
                        Swal.fire({ icon: 'error', title: 'Lỗi', text: result.message });
                        isSpinning = false;
                        $('#btnSpin').prop('disabled', false).html('<i class="fas fa-play"></i> QUAY');
                        return;
                    }

                    // Cập nhật lượt quay
                    if (currentTab === 1) {
                        drinkSpins = result.drinkSpins ?? (drinkSpins - 1);
                        $('#spinCount').text(drinkSpins);
                    } else {
                        foodSpins = result.foodSpins ?? (foodSpins - 1);
                        $('#spinCount').text(foodSpins);
                    }

                    // Tính góc quay — TÌM INDEX TRONG MẢNG LOCAL (hỗ trợ shuffle/sort)
                    const numSlices = prizes.length;
                    const sliceAngle = 360 / numSlices;
                    let targetIndex = prizes.findIndex(p => p.id === result.wonPrizeId);
                    if (targetIndex < 0) targetIndex = Math.floor(Math.random() * numSlices);

                    // Góc để ô trúng nằm ở mũi tên (TOP = 270° trong tọa độ Canvas)
                    const targetAngle = 270 - (targetIndex * sliceAngle + sliceAngle / 2);
                    const totalRotation = 360 * 8 + targetAngle; // 8 vòng + góc đích

                    const wheel = $('#wheelCanvas');
                    wheel.css({
                        'transition': 'none',
                        'transform': 'rotate(0deg)'
                    });

                    // Force reflow
                    wheel[0].offsetHeight;

                    wheel.css({
                        'transition': 'transform 5s cubic-bezier(0.17, 0.67, 0.12, 0.99)',
                        'transform': 'rotate(' + totalRotation + 'deg)'
                    });

                    // Hiện kết quả sau animation
                    setTimeout(function () {
                        isSpinning = false;
                        $('#btnSpin').prop('disabled', false).html('<i class="fas fa-play"></i> QUAY');

                        if (result.hasRealPrize) {
                            Swal.fire({
                                icon: 'success',
                                title: '🎉 Chúc mừng!',
                                html: '<div style="font-size:1.2em">Bạn đã trúng:<br><strong style="color:#e74c3c;font-size:1.4em">' + result.prizeName + '</strong></div>',
                                confirmButtonText: 'Tuyệt vời!',
                                confirmButtonColor: '#27ae60',
                                showClass: { popup: 'animate__animated animate__bounceIn' }
                            });
                        } else {
                            Swal.fire({
                                icon: 'info',
                                title: '😊 Chúc bạn may mắn lần sau!',
                                text: 'Hãy thử lại nhé!',
                                confirmButtonColor: '#3085d6'
                            });
                        }
                    }, 5500);
                },
                error: function () {
                    Swal.fire({ icon: 'error', title: 'Lỗi kết nối', text: 'Không thể kết nối tới server!' });
                    isSpinning = false;
                    $('#btnSpin').prop('disabled', false).html('<i class="fas fa-play"></i> QUAY');
                }
            });
        }
    </script>
}

<style>
    /* === LUCKY WHEEL PAGE === */
    .wheel-page {
        min-height: 80vh;
        padding: 40px 0;
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        position: relative;
        overflow: hidden;
    }

    .wheel-page::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255, 215, 0, 0.05) 0%, transparent 70%);
        animation: shimmer 10s ease-in-out infinite;
    }

    @@keyframes shimmer {
        0%, 100% { transform: rotate(0deg); }
        50% { transform: rotate(180deg); }
    }

    .wheel-container {
        position: relative;
        z-index: 1;
    }

    /* Tiêu đề */
    .wheel-title {
        color: #ffd700;
        font-family: 'Dancing Script', cursive;
        font-size: 3rem;
        text-shadow: 0 0 20px rgba(255, 215, 0, 0.5);
        margin-bottom: 5px;
    }

    .wheel-subtitle {
        color: rgba(255, 255, 255, 0.7);
        font-size: 1.1rem;
    }

    /* Tab buttons */
    .wheel-tabs {
        display: flex;
        gap: 12px;
        justify-content: center;
        margin: 25px 0;
    }

    .wheel-tab {
        padding: 12px 30px;
        border: 2px solid rgba(255, 255, 255, 0.2);
        border-radius: 50px;
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.7);
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .wheel-tab:hover {
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.4);
    }

    .wheel-tab.active {
        background: linear-gradient(135deg, #f39c12, #e74c3c);
        border-color: transparent;
        color: #fff;
        box-shadow: 0 4px 20px rgba(243, 156, 18, 0.4);
        transform: scale(1.05);
    }

    /* Spin counter */
    .spin-info {
        text-align: center;
        margin: 20px 0;
    }

    .spin-count-box {
        display: inline-block;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 16px;
        padding: 15px 35px;
        color: #fff;
    }

    .spin-count-box .number {
        font-size: 2.5rem;
        font-weight: 800;
        color: #ffd700;
        text-shadow: 0 0 10px rgba(255, 215, 0, 0.6);
    }

    .spin-count-box .label {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.7);
        display: block;
    }

    /* Wheel wrapper */
    .wheel-wrapper {
        position: relative;
        width: 500px;
        height: 500px;
        margin: 30px auto;
    }

    /* Canvas */
    #wheelCanvas {
        width: 500px;
        height: 500px;
        border-radius: 50%;
        box-shadow:
            0 0 0 8px #2c3e50,
            0 0 0 12px #ffd700,
            0 0 0 16px #2c3e50,
            0 0 40px rgba(255, 215, 0, 0.3);
        transform-origin: center center;
    }

    /* Mũi tên chỉ */
    .wheel-pointer {
        position: absolute;
        top: -18px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        filter: drop-shadow(0 3px 6px rgba(0, 0, 0, 0.4));
    }

    .wheel-pointer svg {
        width: 36px;
        height: 36px;
    }

    /* Nút quay */
    .spin-btn-wrap {
        text-align: center;
        margin-top: 30px;
    }

    #btnSpin {
        padding: 16px 60px;
        font-size: 1.3rem;
        font-weight: 800;
        letter-spacing: 2px;
        border: none;
        border-radius: 50px;
        background: linear-gradient(135deg, #f39c12, #e74c3c);
        color: #fff;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 6px 25px rgba(243, 156, 18, 0.4);
    }

    #btnSpin:hover:not(:disabled) {
        transform: translateY(-3px);
        box-shadow: 0 10px 35px rgba(243, 156, 18, 0.5);
    }

    #btnSpin:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    /* Nút xáo trộn / sắp xếp */
    .wheel-tools {
        display: flex;
        gap: 12px;
        justify-content: center;
        margin-top: 20px;
    }

    .wheel-tool-btn {
        padding: 10px 24px;
        border: 2px solid rgba(255, 255, 255, 0.2);
        border-radius: 50px;
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.8);
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .wheel-tool-btn:hover {
        background: rgba(255, 255, 255, 0.18);
        color: #fff;
        border-color: rgba(255, 215, 0, 0.5);
        transform: translateY(-2px);
    }

    /* Hướng dẫn */
    .wheel-rules {
        margin-top: 40px;
    }

    .rules-card {
        background: rgba(255, 255, 255, 0.06);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        padding: 25px 30px;
        color: rgba(255, 255, 255, 0.85);
    }

    .rules-card h5 {
        color: #ffd700;
        margin-bottom: 15px;
    }

    .rules-card ul {
        padding-left: 20px;
    }

    .rules-card ul li {
        margin-bottom: 8px;
        line-height: 1.6;
    }

    .rules-card .highlight {
        color: #ffd700;
        font-weight: 700;
    }

    /* Link rewards */
    .rewards-link {
        display: inline-block;
        margin-top: 15px;
        color: #ffd700;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .rewards-link:hover {
        color: #fff;
        text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
    }

    /* Particles decoration */
    .particle {
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 215, 0, 0.3);
        animation: float 6s ease-in-out infinite;
    }

    .particle:nth-child(1) { width: 10px; height: 10px; top: 10%; left: 10%; animation-delay: 0s; }
    .particle:nth-child(2) { width: 15px; height: 15px; top: 20%; right: 15%; animation-delay: 1s; }
    .particle:nth-child(3) { width: 8px; height: 8px; bottom: 30%; left: 20%; animation-delay: 2s; }
    .particle:nth-child(4) { width: 12px; height: 12px; bottom: 15%; right: 10%; animation-delay: 3s; }
    .particle:nth-child(5) { width: 6px; height: 6px; top: 50%; left: 5%; animation-delay: 4s; }

    @@keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.3; }
        50% { transform: translateY(-20px) rotate(180deg); opacity: 0.8; }
    }
</style>

<div class="wheel-page">
    <!-- Decorative particles -->
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>

    <div class="container wheel-container">
        <div class="text-center">
            <h1 class="wheel-title">🎡 Vòng Quay May Mắn</h1>
            <p class="wheel-subtitle">Quay ngay để nhận quà hấp dẫn từ FastFood!</p>
        </div>

        <!-- TABS -->
        <div class="wheel-tabs">
            <button id="tabDrink" class="wheel-tab active" onclick="switchTab(1)">
                🥤 Vòng quay Nước
            </button>
            <button id="tabFood" class="wheel-tab" onclick="switchTab(2)">
                🍔 Vòng quay Đồ ăn
            </button>
        </div>

        <!-- SỐ LƯỢT QUAY -->
        <div class="spin-info">
            <div class="spin-count-box">
                <span class="number" id="spinCount">0</span>
                <span class="label" id="spinLabel">lượt quay</span>
            </div>
        </div>

        <!-- VÒNG QUAY -->
        <div class="row justify-content-center">
            <div class="col-md-6 d-flex justify-content-center">
                <div class="wheel-wrapper">
                    <!-- Mũi tên -->
                    <div class="wheel-pointer">
                        <svg viewBox="0 0 40 40">
                            <polygon points="20,35 8,8 32,8" fill="#e74c3c" stroke="#ffd700" stroke-width="2"/>
                        </svg>
                    </div>
                    <canvas id="wheelCanvas" width="500" height="500"></canvas>
                </div>
            </div>
        </div>

        <!-- NÚT XÁO TRỘN / SẮP XẾP -->
        <div class="wheel-tools">
            <button class="wheel-tool-btn" onclick="shuffleWheel()">
                <i class="fas fa-random"></i> Xáo trộn
            </button>
        </div>

        <!-- NÚT QUAY -->
        <div class="spin-btn-wrap">
            <button id="btnSpin" onclick="spinWheel()">
                <i class="fas fa-play"></i> QUAY
            </button>
        </div>

        <!-- HƯỚNG DẪN + LINK XEM QUÀ -->
        <div class="row justify-content-center mt-4">
            <div class="col-md-8">
                <div class="rules-card">
                    <h5><i class="fas fa-info-circle"></i> Cách nhận lượt quay</h5>
                    <ul>
                        <li>Đơn hàng từ <span class="highlight">100.000đ</span> đến dưới 300.000đ → Nhận <span class="highlight">1 lượt quay Nước</span> 🥤</li>
                        <li>Đơn hàng từ <span class="highlight">300.000đ</span> trở lên → Nhận <span class="highlight">1 lượt quay Đồ ăn + 1 lượt quay Nước</span> 🍔🥤</li>
                    </ul>

                    <a href="@Url.Action("MyRewards", "Wheel")" class="rewards-link">
                        <i class="fas fa-gift"></i> Xem quà đã trúng của tôi →
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
