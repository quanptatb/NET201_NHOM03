@model IEnumerable<WebBanThucAnNhanh.Models.OptionGroup>
@{
    ViewData["Title"] = "Menu Topping & Size";
    // KHÔNG khai báo Layout ở đây để hệ thống tự dùng _Layout.cshtml (giao diện khách)
}

<div class="container" style="padding-top: 120px; padding-bottom: 60px;">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary" style="font-family: 'Dancing Script', cursive; font-size: 3rem;">
            Các Tùy Chọn & Topping
        </h2>
        <p class="text-muted">Khám phá các loại kích cỡ và topping hấp dẫn để món ăn thêm phần trọn vị!</p>
    </div>

    <div class="row g-4">
        @foreach (var group in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                    <div class="card-header bg-warning text-dark py-3 border-0">
                        <h5 class="mb-0 fw-bold">
                            <i class="fas fa-star me-2 text-white"></i>@group.Name
                        </h5>
                        <small class="text-dark">
                            <i class="fas fa-info-circle"></i> 
                            @(group.IsMultiSelect ? "Có thể chọn nhiều mục cùng lúc" : "Chỉ được chọn 1 mục")
                        </small>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @foreach (var item in group.OptionItems)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                    <span class="fw-semibold text-secondary">@item.Name</span>
                                    @if (item.AdditionalPrice > 0)
                                    {
                                        <span class="badge bg-danger rounded-pill fs-6">+@item.AdditionalPrice.ToString("N0") đ</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success rounded-pill fs-6">Miễn phí</span>
                                    }
                                </li>
                            }
                            @if (!group.OptionItems.Any())
                            {
                                <li class="list-group-item text-muted text-center py-3">Đang cập nhật...</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
</div>