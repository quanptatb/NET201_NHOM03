@model WebBanThucAnNhanh.Models.FastFood
@{
    ViewData["Title"] = Model.NameFastFood + " - Chi tiết sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="product-detail-section">
    <div class="container">
        <nav class="product-breadcrumb">
            <a href="@Url.Action("Index", "Home")"><i class="fas fa-home"></i> Trang chủ</a>
            <i class="fas fa-chevron-right"></i>
            <a href="@Url.Action("Index", "Home")#menu">Thực đơn</a>
            <i class="fas fa-chevron-right"></i>
            <span>@Model.NameFastFood</span>
        </nav>

        <div class="product-detail-card">
            <div class="product-detail-grid">
                <div class="product-detail-image">
                    <div class="image-wrapper">
                        @if (!string.IsNullOrEmpty(Model.Image))
                        {
                            <img src="~/images/@Model.Image" alt="@Model.NameFastFood" />
                        }
                        else
                        {
                            <div class="no-image">
                                <i class="fas fa-hamburger"></i>
                                <span>Chưa có hình ảnh</span>
                            </div>
                        }
                    </div>
                    @if (Model.Theme != null)
                    {
                        <div class="product-theme-badge">
                            <i class="fas fa-fire"></i> @Model.Theme.NameTheme
                        </div>
                    }
                </div>

                <div class="product-detail-info">
                    <div class="product-category-tag">
                        <i class="fas fa-tag"></i>
                        @Html.DisplayFor(model => model.TypeOfFastFood.NameTypeOfFastFood)
                    </div>

                    <h1 class="product-detail-name">@Model.NameFastFood</h1>

                    <div class="product-detail-rating">
                        <div class="stars">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                        </div>
                        <span class="rating-text">5.0 (Đánh giá tuyệt vời)</span>
                    </div>

                    <div class="product-detail-price">
                        <span class="price-value">@Model.Price.ToString("#,##0") đ</span>
                    </div>

                    <div class="product-detail-desc">
                        <h3><i class="fas fa-info-circle"></i> Mô tả sản phẩm</h3>
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <p>@Model.Description</p>
                        }
                        else
                        {
                            <p class="no-desc"><i>Đang cập nhật mô tả...</i></p>
                        }
                    </div>

                    <div class="product-detail-status">
                        <div class="status-item">
                            <i class="fas fa-box"></i>
                            <div>
                                <span class="status-label">Tình trạng</span>
                                @if (Model.Status && Model.Quantity > 0)
                                {
                                    <span class="status-value in-stock"><i class="fas fa-check-circle"></i> Còn hàng</span>
                                }
                                else
                                {
                                    <span class="status-value out-of-stock"><i class="fas fa-times-circle"></i> Hết hàng</span>
                                }
                            </div>
                        </div>
                        <div class="status-item">
                            <i class="fas fa-truck"></i>
                            <div>
                                <span class="status-label">Giao hàng</span>
                                <span class="status-value">Miễn phí trong 30 phút</span>
                            </div>
                        </div>
                    </div>

                    <div class="product-detail-actions">
                        @if (Model.Status && Model.Quantity > 0)
                        {
                            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="w-100" id="addToCartForm">
                                <input type="hidden" name="id" value="@Model.IdFastFood" />

                                <div class="options-section mb-4 text-start">
                                    @if (ViewBag.Options != null)
                                    {
                                        foreach (var group in ViewBag.Options)
                                        {
                                            <div class="option-group mb-3 p-3 border rounded shadow-sm bg-light">
                                                <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">
                                                    <i class="fas fa-list-ul text-warning me-2"></i>@group.Name
                                                    @if (group.IsMultiSelect)
                                                    {
                                                        <small class="text-muted fw-normal">(Có thể chọn nhiều)</small>
                                                    }
                                                </h6>
                                                <div class="row">
                                                    @foreach (var item in group.OptionItems)
                                                    {
                                                        <div class="col-sm-6 mb-2">
                                                            <div class="form-check custom-checkbox">
                                                                <input class="form-check-input option-input"
                                                                       type="@(group.IsMultiSelect ? "checkbox" : "radio")"
                                                                       name="@(group.IsMultiSelect ? "selectedOptionIds" : $"group_{group.Id}")"
                                                                       value="@item.Id" id="option_@item.Id"
                                                                       data-price="@item.AdditionalPrice" />
                                                                <label class="form-check-label d-flex justify-content-between w-100"
                                                                       for="option_@item.Id" style="cursor:pointer;">
                                                                    <span>@item.Name</span>
                                                                    @if (item.AdditionalPrice > 0)
                                                                    {
                                                                        <span class="text-danger fw-bold">+@item.AdditionalPrice.ToString("#,##0")đ</span>
                                                                    }
                                                                </label>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>

                                <div class="d-flex align-items-center mb-3">
                                    <label class="fw-bold me-3 text-nowrap">Số lượng:</label>
                                    <div class="input-group w-25 me-3">
                                        <input type="number" name="quantity" class="form-control text-center" value="1"
                                               min="1" max="@Model.Quantity" />
                                    </div>

                                    <button type="submit" class="btn-add-cart border-0 flex-grow-1" style="height: 45px;">
                                        <i class="fas fa-cart-plus"></i> Thêm vào giỏ
                                    </button>
                                </div>
                            </form>

                            <script>
                                document.getElementById('addToCartForm').addEventListener('submit', function(e) {
                                    // Tìm tất cả radio button đang được chọn và tạo hidden input cho chúng
                                    var radios = this.querySelectorAll('input[type="radio"]:checked');
                                    radios.forEach(function(radio) {
                                        if (radio.name !== 'selectedOptionIds') {
                                            var hidden = document.createElement('input');
                                            hidden.type = 'hidden';
                                            hidden.name = 'selectedOptionIds';
                                            hidden.value = radio.value;
                                            e.target.appendChild(hidden);
                                        }
                                    });
                                });
                            </script>
                        }
                        else
                        {
                            <button class="btn-add-cart disabled w-100 mb-3" disabled>
                                <i class="fas fa-ban"></i> Tạm hết hàng
                            </button>
                        }

                        <a href="@Url.Action("Index", "Home")#menu"
                           class="btn-back-menu d-block text-center mt-2 w-100">
                            <i class="fas fa-arrow-left"></i> Tiếp tục mua hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @if (ViewBag.AddOnItems != null && ViewBag.AddOnItems.Count > 0)
        {
            <div class="cross-sell-section mt-5 bg-white p-4 rounded shadow-sm border-top border-danger border-3">
                <h4 class="fw-bold mb-4 text-danger"><i class="fas fa-gift me-2"></i> Mua kèm giảm thêm</h4>
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4">
                    @foreach (var addon in ViewBag.AddOnItems)
                        {
                            var discount = (decimal)addon.DiscountPercentage / 100m;
                            var discountedPrice = addon.AddOnFastFood.Price * (1m - discount);
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 bg-light">
                                <img src="~/images/@addon.AddOnFastFood.Image" class="card-img-top p-3" alt="@addon.AddOnFastFood.NameFastFood" style="object-fit: contain; height: 160px; mix-blend-mode: multiply;">
                                <div class="card-body text-center d-flex flex-column">
                                    <h6 class="card-title fw-bold text-dark">@addon.AddOnFastFood.NameFastFood</h6>
                                    <div class="mt-auto">
                                        <p class="card-text mb-0 text-muted text-decoration-line-through small">
                                            @addon.AddOnFastFood.Price.ToString("#,##0") đ
                                        </p>
                                        <p class="card-text text-danger fw-bold fs-5 mb-3">
                                            @discountedPrice.ToString("#,##0") đ 
                                            <span class="badge bg-danger ms-1 fs-6">-@addon.DiscountPercentage%</span>
                                        </p>
                                        <form asp-controller="Cart" asp-action="AddBundle" method="post">
                                            <input type="hidden" name="mainId" value="@Model.IdFastFood" />
                                            <input type="hidden" name="addOnId" value="@addon.AddOnFastFood.IdFastFood" />
                                            <input type="hidden" name="discount" value="@addon.DiscountPercentage" />
                                            <button type="submit" class="btn btn-warning w-100 fw-bold rounded-pill text-dark">
                                                <i class="fas fa-cart-plus"></i> Mua kèm ngay
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (ViewBag.RelatedProducts != null &&
                ((IEnumerable<WebBanThucAnNhanh.Models.FastFood>)ViewBag.RelatedProducts).Any())
        {
            <div class="related-products-section mt-5">
                <div class="section-title text-center">
                    <h2>Sản Phẩm <span class="highlight">Liên Quan</span></h2>
                </div>
                <div class="menu-content active-content" style="display: grid;">
                    @foreach (var item in (IEnumerable<WebBanThucAnNhanh.Models.FastFood>)ViewBag.RelatedProducts)
                    {
                        <div class="menu-item animate-on-scroll">
                            @* IMAGE SECTION WITH BADGES *@
                            <div class="menu-item-img">
                                @if (item.Quantity <= 0 || !item.Status)
                                {
                                    <div class="menu-item-badge badge-soldout">Hết hàng</div>
                                }
                                else if (item.Price > 50000)
                                {
                                    <div class="menu-item-badge badge-hot">Bán chạy</div>
                                }
                                <img src="~/images/@item.Image" alt="@item.NameFastFood" loading="lazy" />
                            </div>

                            @* CONTENT SECTION *@
                            <div class="menu-item-content">
                                <div class="menu-item-title">
                                    <h4>@item.NameFastFood</h4>
                                    <div class="menu-item-price">@item.Price.ToString("#,##0") đ</div>
                                </div>
                                <p class="menu-item-text" title="@item.Description">@item.Description</p>
                                <div class="menu-item-order">
                                    <div class="menu-item-rating">
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                    </div>
                                    <div class="action-group">
                                        @* NÚT XEM CHI TIẾT *@
                                        <a href="@Url.Action("Details", "Home", new { id = item.IdFastFood })"
                                           class="btn-sm-custom">
                                            <i class="fas fa-eye"></i><span>Xem</span>
                                        </a>
                                        @* NÚT THÊM VÀO GIỎ *@
                                        @if (item.Quantity > 0 && item.Status)
                                        {
                                            <a href="@Url.Action("AddToCart", "Cart", new { id = item.IdFastFood })"
                                               class="btn-sm-custom">
                                                <i class="fas fa-cart-plus"></i><span>Thêm</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn-sm-custom" disabled style="opacity: 0.6; cursor: not-allowed;">
                                                <i class="fas fa-ban"></i><span>Hết</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>