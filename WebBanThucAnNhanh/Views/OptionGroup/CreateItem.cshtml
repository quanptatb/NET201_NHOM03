@model WebBanThucAnNhanh.Models.OptionItem
@{
    ViewData["Title"] = "Thêm Tùy Chọn Con";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container py-4">
    <div class="card shadow-sm max-w-md mx-auto" style="max-width: 600px;">
        <div class="card-body">
            <h3 class="fw-bold mb-4">Thêm Lựa Chọn Mới</h3>
            <form asp-action="CreateItem">
                <input type="hidden" asp-for="OptionGroupId" value="@ViewBag.GroupId" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Tên Lựa Chọn (VD: Size L, Trân Châu Trắng)</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="AdditionalPrice" class="form-label fw-bold">Giá Cộng Thêm (VNĐ)</label>
                    <input asp-for="AdditionalPrice" type="number" step="1000" class="form-control" placeholder="Ví dụ: 10000" required />
                    <span asp-validation-for="AdditionalPrice" class="text-danger"></span>
                    <small class="text-muted">Nhập 0 nếu đây là lựa chọn miễn phí (VD: Ít đá).</small>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">Lưu Lựa Chọn</button>
                    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>