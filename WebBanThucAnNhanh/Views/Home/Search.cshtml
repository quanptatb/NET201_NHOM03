@model IEnumerable<WebBanThucAnNhanh.Models.FastFood>
@{
    ViewData["Title"] = "Kết quả tìm kiếm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="menu">
    <div class="container">
        <div class="section-title text-center">
            <h2>Kết Quả <span class="highlight">Tìm Kiếm</span></h2>
        </div>

        @* Form tìm kiếm lại *@
        <div class="advanced-search-container">
            <form method="get" asp-action="Search" asp-controller="Home" class="mb-4">
                <div class="row align-items-center">
                    <div class="col-md-4">
                        <input type="text" name="keyword" class="form-control" placeholder="Tìm tên món..."
                            value="@ViewBag.Keyword">
                    </div>
                    <div class="col-md-3">
                        <select name="themeId" class="form-control">
                            <option value="">-- Chọn Chủ đề --</option>
                            @if (ViewBag.Themes != null)
                            {
                                foreach (var theme in ViewBag.Themes)
                                {
                                    if (ViewBag.CurrentTheme == theme.IdTheme)
                                    {
                                        <option value="@theme.IdTheme" selected>@theme.NameTheme</option>
                                    }
                                    else
                                    {
                                        <option value="@theme.IdTheme">@theme.NameTheme</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="number" name="minPrice" class="form-control" placeholder="Giá từ"
                            value="@ViewBag.MinPrice">
                    </div>
                    <div class="col-md-2">
                        <input type="number" name="maxPrice" class="form-control" placeholder="Đến giá"
                            value="@ViewBag.MaxPrice">
                    </div>
                    <div class="col-md-1">
                        <button type="submit" class="btn btn-primary w-200">
                            <i class="fas fa-search"></i> Tìm kiếm
                        </button>
                    </div>
                </div>
            </form>
        </div>

        @* Hiển thị kết quả *@
        <div style="margin-top: 30px;">
            @if (Model == null || !Model.Any())
            {
                <div class="text-center">
                    <p class="text-muted">Không tìm thấy món ăn nào phù hợp.</p>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Về trang chủ</a>
                </div>
            }
            else
            {
                <div class="menu-content active-content" style="display: grid;">
                    @foreach (var item in Model)
                    {
                        <div class="menu-item animate-on-scroll">
                            @* IMAGE SECTION WITH BADGES *@
                            <div class="menu-item-img">
                                @if (item.Quantity <= 0 || !item.Status)
                                {
                                    <div class="menu-item-badge badge-soldout">Hết hàng</div>
                                }
                                else if (item.Price > 50000)
                                {
                                    <div class="menu-item-badge badge-hot">Bán chạy</div>
                                }
                                <img src="~/images/@item.Image" alt="@item.NameFastFood" loading="lazy" />
                            </div>

                            @* CONTENT SECTION *@
                            <div class="menu-item-content">
                                <div class="menu-item-title">
                                    <h4>@item.NameFastFood</h4>
                                    <div class="menu-item-price">@item.Price.ToString("#,##0") đ</div>
                                </div>
                                <p class="menu-item-text" title="@item.Description">
                                    @if (item.TypeOfFastFood != null)
                                    {
                                        <span class="text-primary" style="font-weight: 700; font-size: 1.3rem;">#@item.TypeOfFastFood.NameTypeOfFastFood</span><br />
                                    }
                                    @item.Description
                                </p>
                                <div class="menu-item-order">
                                    <div class="menu-item-rating">
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                    </div>
                                    <div class="action-group">
                                        @* NÚT XEM CHI TIẾT *@
                                        <a href="@Url.Action("Details", "Home", new { id = item.IdFastFood })" class="btn-sm-custom">
                                            <i class="fas fa-eye"></i><span>Xem</span>
                                        </a>
                                        @* NÚT THÊM VÀO GIỎ *@
                                        @if (item.Quantity > 0 && item.Status)
                                        {
                                            <a href="@Url.Action("AddToCart", "Cart", new { id = item.IdFastFood })" class="btn-sm-custom">
                                                <i class="fas fa-cart-plus"></i><span>Thêm</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn-sm-custom" disabled style="opacity: 0.6; cursor: not-allowed;">
                                                <i class="fas fa-ban"></i><span>Hết</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</section>