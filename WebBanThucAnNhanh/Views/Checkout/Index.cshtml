@model WebBanThucAnNhanh.Models.Order
@{
    ViewData["Title"] = "Thanh toán";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 pt-5 checkout-section">
    <div class="row pt-4">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="fas fa-money-bill-wave"></i> Thông tin thanh toán</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Index" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-4 text-center">
                            <h5>Tổng tiền tạm tính:</h5>
                            <h4>@ViewBag.OriginalTotal?.ToString("N0") VNĐ</h4>
                            
                            @if (ViewBag.RankDiscount != null && ViewBag.RankDiscount > 0)
                            {
                                <h5 class="text-info mt-2">Chiết khấu hạng (@ViewBag.RankName): -@ViewBag.RankDiscount?.ToString("N0") VNĐ</h5>
                            }

                            @if (!string.IsNullOrEmpty(ViewBag.VoucherCode))
                            {
                                <h5 class="text-success mt-2">Mã giảm giá (@ViewBag.VoucherCode): -@ViewBag.DiscountAmount?.ToString("N0") VNĐ</h5>
                            }
                            
                            <h5>Tổng tiền cần thanh toán:</h5>
                            <h2 class="text-danger">@ViewBag.FinalTotal?.ToString("N0") VNĐ</h2>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Người nhận:</label>
                            <input type="text" class="form-control" value="@User.Identity.Name" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-bold">Số điện thoại nhận hàng</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại..." required />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ShippingAddress" class="form-label fw-bold">Địa chỉ giao hàng</label>
                            <textarea asp-for="ShippingAddress" class="form-control" rows="3" placeholder="Số nhà, đường, phường, quận..." required></textarea>
                            <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                Xác nhận đặt hàng
                            </button>
                            <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">
                                Quay lại giỏ hàng
                            </a>
                        </div>
                    </form>
                    
                    <hr class="my-4" />
                    
                    @if (!string.IsNullOrEmpty(ViewBag.VoucherCode))
                    {
                        <form asp-action="RemoveVoucher" asp-controller="Checkout" method="post" class="mt-2 text-center">
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash-alt"></i> Gỡ mã giảm giá</button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="ApplyVoucher" asp-controller="Checkout" method="post" class="mt-3 d-flex justify-content-center align-items-center">
                            <label class="fw-bold me-2 mb-0">Mã giảm giá:</label>
                            <input type="text" name="voucherCode" class="form-control me-2" style="max-width: 200px;" placeholder="Nhập mã..." required />
                            <button type="submit" class="btn btn-primary">Áp dụng</button>
                        </form>
                    }

                    @if (TempData["VoucherError"] != null)
                    {
                        <div class="text-danger mt-2 text-center small"><i class="fas fa-times-circle"></i> @TempData["VoucherError"]</div>
                    }
                    @if (TempData["VoucherSuccess"] != null)
                    {
                        <div class="text-success mt-2 text-center small"><i class="fas fa-check-circle"></i> @TempData["VoucherSuccess"]</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
