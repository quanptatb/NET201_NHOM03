@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Dashboard Quản trị</h2>
        <div>
            <a href="@Url.Action("Index", "Order")" class="btn btn-primary me-2"><i class="fas fa-box"></i> Quản lý Đơn hàng</a>
            <a href="@Url.Action("Index", "User")" class="btn btn-secondary"><i class="fas fa-users"></i> Quản lý Người dùng</a>
        </div>
    </div>

    <!-- Metrics Cards -->
    <div class="row g-4 mb-5">
        <!-- Doanh thu ngày -->
        <div class="col-md-3">
            <div class="card bg-success text-white h-100 shadow-sm border-0 rounded-pills-custom">
                <div class="card-body py-4 text-center">
                    <h5 class="card-title text-uppercase mb-3" style="font-size: 0.9rem; letter-spacing: 1px;">Doanh thu Hôm nay</h5>
                    <h3 class="card-text fw-bold">@ViewBag.DailyRevenue.ToString("#,##0") đ</h3>
                    <div class="mt-3"><i class="fas fa-money-bill-wave fa-2x opacity-50"></i></div>
                </div>
            </div>
        </div>

        <!-- Doanh thu tháng -->
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100 shadow-sm border-0 rounded-pills-custom">
                <div class="card-body py-4 text-center">
                    <h5 class="card-title text-uppercase mb-3" style="font-size: 0.9rem; letter-spacing: 1px;">Doanh thu Tháng này</h5>
                    <h3 class="card-text fw-bold">@ViewBag.MonthlyRevenue.ToString("#,##0") đ</h3>
                    <div class="mt-3"><i class="fas fa-wallet fa-2x opacity-50"></i></div>
                </div>
            </div>
        </div>

        <!-- Số đơn mới -->
        <div class="col-md-3">
            <div class="card bg-warning text-dark h-100 shadow-sm border-0 rounded-pills-custom">
                <div class="card-body py-4 text-center">
                    <h5 class="card-title text-uppercase mb-3" style="font-size: 0.9rem; letter-spacing: 1px;">Số đơn Mới</h5>
                    <h3 class="card-text fw-bold">@ViewBag.NewOrdersCount</h3>
                    <div class="mt-3"><i class="fas fa-bell fa-2x opacity-50"></i></div>
                </div>
            </div>
        </div>

        <!-- Tỉ lệ thành công/hủy -->
        <div class="col-md-3">
            <div class="card bg-danger text-white h-100 shadow-sm border-0 rounded-pills-custom">
                <div class="card-body py-4 text-center">
                    <h5 class="card-title text-uppercase mb-3" style="font-size: 0.9rem; letter-spacing: 1px;">Tỉ lệ Giao Thành công</h5>
                    <h3 class="card-text fw-bold">@ViewBag.SuccessRate%</h3>
                    <div class="mt-3">
                        <small class="d-block text-white-50">Thành công: @ViewBag.SuccessOrdersCount</small>
                        <small class="d-block text-white-50">Hủy: @ViewBag.CancelledOrdersCount</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-4">Biểu đồ Trạng thái Đơn hàng Đã Xử Lý</h5>
                    <div class="progress" style="height: 30px; font-size: 1rem;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: @ViewBag.SuccessRate%;" aria-valuenow="@ViewBag.SuccessRate" aria-valuemin="0" aria-valuemax="100">
                            @if(ViewBag.SuccessRate > 5) { <text>@ViewBag.SuccessRate% Thành công</text> }
                        </div>
                        <div class="progress-bar bg-danger" role="progressbar" style="width: @(100 - ViewBag.SuccessRate)%;" aria-valuenow="@(100 - ViewBag.SuccessRate)" aria-valuemin="0" aria-valuemax="100">
                             @if(100 - ViewBag.SuccessRate > 5) { <text>@(100 - ViewBag.SuccessRate)% Hủy</text> }
                        </div>
                    </div>
                    <div class="mt-3 d-flex justify-content-center text-muted">
                        <span class="me-4"><i class="fas fa-circle text-success me-1"></i> Giao Thành công</span>
                        <span><i class="fas fa-circle text-danger me-1"></i> Khách Hủy / Giao Thất bại</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pills-custom {
        border-radius: 15px;
    }
    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>
