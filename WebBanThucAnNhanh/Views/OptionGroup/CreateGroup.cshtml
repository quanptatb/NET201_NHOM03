@model WebBanThucAnNhanh.Models.OptionGroup
@{
    ViewData["Title"] = "Thêm Nhóm Tùy Chọn";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container py-4">
    <div class="card shadow-sm max-w-md mx-auto" style="max-width: 600px;">
        <div class="card-body">
            <h3 class="fw-bold mb-4">Thêm Nhóm Tùy Chọn</h3>
            <form asp-action="CreateGroup">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Tên Nhóm (VD: Size, Loại Đá, Topping)</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-4 form-check">
                    <input asp-for="IsMultiSelect" class="form-check-input" type="checkbox" />
                    <label asp-for="IsMultiSelect" class="form-check-label fw-bold">
                        Cho phép chọn nhiều (Check vào đây nếu là Topping, bỏ check nếu là Size/Mức đá)
                    </label>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Lưu lại</button>
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>